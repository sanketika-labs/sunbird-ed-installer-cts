#!/usr/bin/env bash
#
# Terragrunt Orchestration Script
# This script enforces proper execution order and prevents individual module runs
#
# Usage:
#   ./tg init     - Initialize all modules
#   ./tg plan     - Plan all modules
#   ./tg apply    - Apply all modules
#   ./tg destroy  - Destroy all modules (reverse order)
#   ./tg output   - Show outputs from all modules
#   ./tg validate - Validate all modules
#
# To run a specific module (not recommended):
#   TERRAGRUNT_ALLOW_INDIVIDUAL=true ./tg apply --terragrunt-working-dir ./network
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BLUE}════════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  Terragrunt Orchestrator - $1${NC}"
    echo -e "${BLUE}════════════════════════════════════════════════════════════${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

show_help() {
    cat << EOF
Terragrunt Orchestration Script

Usage: ./tg <command> [options]

Commands:
  init      Initialize all modules in dependency order
  plan      Plan all modules in dependency order
  apply     Apply all modules in dependency order
  destroy   Destroy all modules in reverse dependency order
  output    Show outputs from all modules
  validate  Validate all module configurations
  graph     Show module dependency graph
  help      Show this help message

Options:
  --auto-approve    Skip interactive approval (for apply/destroy)
  --parallelism=N   Limit parallel operations (default: 10)

Environment Variables:
  TERRAGRUNT_ALLOW_INDIVIDUAL=true   Allow running individual modules
  TERRAGRUNT_ORCHESTRATED=true       Set automatically by this script

Module Dependency Order:
  Apply:   random_passwords, network, storage, keys → eks → iam, upload-files → output-file
  Destroy: output-file → upload-files, iam → eks → keys, storage, network, random_passwords

Examples:
  ./tg init                    # Initialize all modules
  ./tg plan                    # Plan all changes
  ./tg apply --auto-approve    # Apply all changes without prompts
  ./tg destroy                 # Destroy all resources

EOF
}

show_graph() {
    cat << 'EOF'
Module Dependency Graph:

┌─────────────────┐     ┌─────────────────┐     ┌─────────────────┐     ┌─────────────────┐
│ random_passwords│     │     storage     │     │      keys       │     │     network     │
│   (no deps)     │     │   (no deps)     │     │   (no deps)     │     │   (no deps)     │
└─────────────────┘     └────────┬────────┘     └────────┬────────┘     └────────┬────────┘
                                 │                       │                       │
                                 │                       │                       │
                                 ▼                       │                       ▼
                        ┌────────────────┐               │              ┌────────────────┐
                        │  upload-files  │               │              │      eks       │
                        └────────────────┘               │              └───────┬────────┘
                                 │                       │                      │
                                 │                       │                      │
                                 ▼                       │                      ▼
                        ┌────────────────────────────────┴──────────────────────┐
                        │                         iam                           │
                        └───────────────────────────┬───────────────────────────┘
                                                    │
                                                    ▼
                        ┌───────────────────────────────────────────────────────┐
                        │                      output-file                      │
                        └───────────────────────────────────────────────────────┘

EOF
}

run_terragrunt() {
    local command=$1
    shift

    # Set orchestrated mode
    export TERRAGRUNT_ORCHESTRATED=true

    print_header "Running: terragrunt run-all $command"
    echo ""

    terragrunt run -- run-all "$command" "$@"

    if [ $? -eq 0 ]; then
        echo ""
        print_success "Command completed successfully"
    else
        echo ""
        print_error "Command failed"
        exit 1
    fi
}

# Main command handler
case "${1:-help}" in
    init)
        shift
        run_terragrunt init "$@"
        ;;
    plan)
        shift
        run_terragrunt plan "$@"
        ;;
    apply)
        shift
        run_terragrunt apply "$@"
        ;;
    destroy)
        shift
        print_warning "This will destroy ALL resources in reverse dependency order!"
        run_terragrunt destroy "$@"
        ;;
    output)
        shift
        run_terragrunt output "$@"
        ;;
    validate)
        shift
        run_terragrunt validate "$@"
        ;;
    graph)
        show_graph
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        print_error "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
